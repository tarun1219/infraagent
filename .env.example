# InfraAgent Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit .env to version control.

# ── OpenAI API (for GPT-4o baseline) ─────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Cost: ~$5 per 300-task run at sc+rag+3r condition
OPENAI_API_KEY=sk-...

# ── Anthropic API (for Claude 3.5 Sonnet baseline) ────────────────────────────
# Get your key at: https://console.anthropic.com/
# Cost: ~$6 per 300-task run at sc+rag+3r condition
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (local model inference) ───────────────────────────────────────────
# Default: http://localhost:11434
# Change if Ollama runs on a remote machine or non-default port
OLLAMA_HOST=http://localhost:11434

# Request timeout in seconds — increase for 70B models on CPU
OLLAMA_TIMEOUT=300

# ── LocalStack (Terraform deployment testing) ─────────────────────────────────
# Required only for deployment gap analysis (Figure 12)
# Start LocalStack: bash scripts/setup_localstack.sh
LOCALSTACK_ENDPOINT=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1

# Dummy credentials for LocalStack (do NOT use real AWS credentials here)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── Kubernetes (kubectl dry-run=server validation) ────────────────────────────
# Required only for Layer 2.5 server-side validation
# Set up kind cluster: bash scripts/setup_kind_cluster.sh
# Leave unset to use the current KUBECONFIG context
# KUBECONFIG=/path/to/kubeconfig
INFRAAGENT_K8S_CONTEXT=kind-infraagent-eval

# ── Zenodo (results data release) ────────────────────────────────────────────
# Required only for: python scripts/prepare_results_release.py --all
# Get a token at: https://zenodo.org/account/settings/applications/
# ZENODO_TOKEN=your_zenodo_token_here
# ZENODO_SANDBOX=1  # Set to 1 to use sandbox.zenodo.org for testing

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/infraagent.log

# ── Terraform plugin cache (avoids re-downloading providers) ──────────────────
TF_PLUGIN_CACHE_DIR=${HOME}/.terraform.d/plugin-cache
